# Supabase (Server-seitig — Service Key, NIEMALS im Client verwenden!)
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_SERVICE_KEY=dein-service-key

# Datenbank (Supabase Postgres Connection String)
DATABASE_URL=postgresql://postgres:PASSWORD@db.DEIN-PROJEKT.supabase.co:5432/postgres

# Redis (fuer spaeteren Einsatz — z.B. Upstash)
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:8081
