# Supabase (Client-seitig — EXPO_PUBLIC_ wird in den Build eingebettet)
EXPO_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Game Server URL (lokale Entwicklung: Android-Emulator -> Host)
# Im Emulator: 10.0.2.2 = localhost des Host-Rechners
EXPO_PUBLIC_SERVER_URL=http://10.0.2.2:3001
